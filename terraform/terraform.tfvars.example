# cp terraform.tfvars.example terraform.tfvars して埋める
region            = "ap-northeast-1"
project           = "namazu"
hmac_secret       = "change-me-32bytes-random-secret" # firmware secrets.h と一致させる
slack_webhook_url = "https://hooks.slack.com/services/XXX/YYY/ZZZ"

# 検知パラメータ（バックテストで調整）
detect_threshold      = 0.5
detect_hold_seconds   = 2.0
detect_window_seconds = 120
raw_retention_days    = 90
